APP_ENV=development
HTTP_PORT=8080
ACCESS_TOKEN_SECRET=super-secret-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
PASSWORD_RESET_DEMO_TOKEN=demo-reset-token
DATABASE_URL=postgres://postgres:postgres@localhost:5432/esports?sslmode=disable
REDIS_URL=redis://localhost:6379/0
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/google-service-account.json
GOOGLE_DEFAULT_WORKSHEET=Sheet1
AUTH_RATE_LIMIT_PER_MINUTE=30

# SMTP (Gmail). Оставьте пустым чтобы отключить email-уведомления.
# Для Gmail создайте App Password: myaccount.google.com → Security → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=your@gmail.com

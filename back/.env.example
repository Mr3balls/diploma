APP_ENV=development
HTTP_PORT=8080

# Сменить на случайную строку в продакшене
ACCESS_TOKEN_SECRET=super-secret-change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
PASSWORD_RESET_DEMO_TOKEN=demo-reset-token

# Docker Compose: используй имена сервисов (postgres, redis)
# Локально без Docker: localhost:5432 / localhost:6379
DATABASE_URL=postgres://postgres:postgres@postgres:5432/esports?sslmode=disable
REDIS_URL=redis://redis:6379/0

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_DEFAULT_WORKSHEET=Sheet1

AUTH_RATE_LIMIT_PER_MINUTE=30

# SMTP (Gmail). Оставьте пустым чтобы отключить email-уведомления.
# Для Gmail: myaccount.google.com → Безопасность → Пароли приложений → Создать
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM=your@gmail.com